<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!--
    Schermo di esplorazione: descrive COM'E' FATTA la schermata, non cosa fa e
    nemmeno che colore ha. Il comportamento vive in EsplorazioneController
    (agganciato tramite gli fx:id e gli onAction); i colori in stile.css
    (agganciato tramite le styleClass).

    Nota: qui non c'e' l'attributo fx:controller. Il controller viene creato a
    mano dall'applicazione e passato al caricatore, cosi' puo' ricevere la
    partita nel costruttore ed essere valido fin dalla nascita.
-->
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      styleClass="schermo"
      alignment="CENTER"
      spacing="12.0"
      prefWidth="560.0"
      prefHeight="420.0">

    <padding>
        <Insets top="30.0" right="40.0" bottom="30.0" left="40.0"/>
    </padding>

    <Label fx:id="nomeStanza" styleClass="titolo-schermo"/>
    <Label fx:id="descrizioneStanza" styleClass="descrizione" wrapText="true"/>
    <Label fx:id="statoNemico" styleClass="scheda-nemico"/>

    <!-- Attivo solo quando la stanza e' sorvegliata: non si attacca il vuoto. -->
    <Button fx:id="bottoneCombatti" text="Combatti!" styleClass="button-attacco" onAction="#combatti"/>

    <Separator/>

    <!-- Le quattro direzioni. Ogni pulsante viene abilitato o disabilitato dal
         controller a seconda delle uscite della stanza corrente. -->
    <HBox alignment="CENTER" spacing="8.0">
        <Button fx:id="bottoneNord" text="Nord" onAction="#vaiNord"/>
        <Button fx:id="bottoneSud" text="Sud" onAction="#vaiSud"/>
        <Button fx:id="bottoneEst" text="Est" onAction="#vaiEst"/>
        <Button fx:id="bottoneOvest" text="Ovest" onAction="#vaiOvest"/>
    </HBox>

    <Separator/>

    <Label fx:id="statoEroe" styleClass="scheda-eroe"/>
    <ProgressBar fx:id="barraEroe" styleClass="barra-vita" prefWidth="240.0" progress="1.0"/>
    <Label fx:id="messaggio" styleClass="messaggio" wrapText="true"/>

    <!-- Il viaggio si puo' interrompere e riprendere. Sempre disponibili: si salva
         quando si vuole, non solo dove il gioco lo concede. -->
    <HBox alignment="CENTER" spacing="8.0">
        <Button fx:id="bottoneSalva" text="Salva" onAction="#salva"/>
        <Button fx:id="bottoneCarica" text="Carica" onAction="#carica"/>
    </HBox>

</VBox>
